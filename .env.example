# ─────────────────────────────────────────────────────────────
# SalesAI — Environment Variables (copy to .env and fill in)
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
LOG_LEVEL=debug

# ─── API ──────────────────────────────────────────────────────
API_PORT=5001
API_PUBLIC_URL=http://localhost:5001
VISITOR_PUBLIC_URL=http://localhost:5174
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ─── Web apps ─────────────────────────────────────────────────
# Console (seller dashboard) + Visitor (public agent link)
VITE_API_URL=http://localhost:5001
VITE_LIVEKIT_URL=ws://localhost:7880
CONSOLE_PORT=5173
VISITOR_PORT=5174

# ─── Mobile (Expo dev build) ──────────────────────────────────
# Copy to apps/mobile/.env — Expo reads env from the app dir, NOT the repo root.
# Physical device: replace localhost with your Mac's LAN IP (ipconfig getifaddr en0);
# the app rewrites the LiveKit URL's localhost to the same host automatically.
EXPO_PUBLIC_API_URL=http://localhost:5001

# ─── Auth ─────────────────────────────────────────────────────
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800

# ─── MongoDB (primary datastore + Atlas Vector Search) ────────
# Local dev uses the mongodb-atlas-local image (Vector Search enabled).
MONGODB_URI=mongodb://localhost:27017/salesai?directConnection=true
EMBEDDING_DIM=3072

# ─── Redis (cache / queue / pub-sub) ──────────────────────────
REDIS_URL=redis://localhost:6380

# ─── Object storage (S3-compatible / MinIO) ───────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=salesai-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# ─── LiveKit (WebRTC realtime) ────────────────────────────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ─── LLM / Embeddings ─────────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_LLM_MODEL=gpt-5.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
ANTHROPIC_API_KEY=

# ─── Speech (chained pipeline alternative) ────────────────────
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
CARTESIA_API_KEY=

# ─── Avatar providers (strategy; pick one via AVATAR_PROVIDER) ─
# tavus | simli | heygen | did | voice-only
AVATAR_PROVIDER=voice-only
TAVUS_API_KEY=
TAVUS_REPLICA_ID=
TAVUS_PERSONA_ID=
SIMLI_API_KEY=
SIMLI_FACE_ID=
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
DID_API_KEY=

# ─── Screen intelligence ──────────────────────────────────────
# AI-driven guided tour: local playwright | browserbase
COBROWSE_PROVIDER=playwright
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ─── Vector store ─────────────────────────────────────────────
# mongodb (Atlas Vector Search, default) | qdrant
VECTOR_STORE=mongodb
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
