{
  "expo": {
    "name": "SalesAI",
    "slug": "salesai",
    "scheme": "salesai",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "plugins": ["expo-router"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.salesai.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "SalesAI uses your microphone so you can talk to your AI sales representative."
      }
    },
    "android": {
      "package": "com.salesai.app",
      "permissions": ["android.permission.RECORD_AUDIO"]
    }
  }
}
