{
  "expo": {
    "name": "SalesAI",
    "slug": "salesai",
    "scheme": "salesai",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "plugins": ["expo-router"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.salesai.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "SalesAI needs access to your microphone to converse with the agent."
      }
    },
    "android": { "package": "com.salesai.app" }
  }
}
